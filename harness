#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$cmd" in
  install)
    exec "$ROOT_DIR/.harness/scripts/setup/install.sh" "$@"
    ;;
  doctor)
    exec "$ROOT_DIR/.harness/scripts/checks/doctor.sh" "$@"
    ;;
  context-check)
    exec mise exec -- node "$ROOT_DIR/.harness/scripts/checks/context-check.mjs" "$@"
    ;;
  rule-check)
    exec mise exec -- node "$ROOT_DIR/.harness/scripts/checks/rule-check.mjs" "$@"
    ;;
  secret-surface-check)
    exec mise exec -- node "$ROOT_DIR/.harness/scripts/checks/secret-surface-check.mjs" "$@"
    ;;
  package-policy-check)
    exec mise exec -- node "$ROOT_DIR/.harness/scripts/checks/package-policy-check.mjs" "$@"
    ;;
  update)
    exec "$ROOT_DIR/.harness/scripts/setup/update.sh" "$@"
    ;;
  update-check)
    exec "$ROOT_DIR/.harness/scripts/setup/update-check.sh" "$@"
    ;;
  manifest)
    exec mise exec -- node "$ROOT_DIR/.harness/scripts/setup/generate-manifest.mjs" "$@"
    ;;
  skills-link)
    exec "$ROOT_DIR/.harness/scripts/setup/skills-link.sh" "$@"
    ;;
  profile)
    exec mise exec -- node "$ROOT_DIR/.harness/scripts/tooling/profile.mjs" "$@"
    ;;
  workflow-check)
    exec "$ROOT_DIR/.harness/scripts/checks/workflow-check.sh" "$@"
    ;;
  notify-decision)
    exec mise exec -- node "$ROOT_DIR/.harness/scripts/agent/notify.mjs" decision "$@"
    ;;
  init-project)
    exec "$ROOT_DIR/.harness/scripts/setup/init-project.sh" "$@"
    ;;
  wire-infisical)
    exec "$ROOT_DIR/.harness/scripts/setup/wire-infisical.sh" "$@"
    ;;
  team)
    exec "$ROOT_DIR/.harness/scripts/agent/team-session.sh" "$@"
    ;;
  codex)
    "$ROOT_DIR/.harness/scripts/agent/agent-preflight.sh" codex
    exec codex "$@"
    ;;
  claude)
    "$ROOT_DIR/.harness/scripts/agent/agent-preflight.sh" claude
    exec claude "$@"
    ;;
  help|--help|-h)
    cat <<'EOF'
사용법:
  ./harness install       하네스 통합 도구를 설치하거나 갱신
  ./harness doctor        로컬 하네스 상태 점검
  ./harness context-check AGENTS.md / CLAUDE.md 컨텍스트 정합성 점검
  ./harness rule-check    네이티브 rule 파일 문서화/연결 상태 점검
  ./harness secret-surface-check
                           GitHub Secret 및 .env.example 노출면 점검
  ./harness package-policy-check
                           패키지 매니저 및 lockfile 정책 점검
  ./harness update        외부 업데이트 확인 또는 shared 하네스 적용
  ./harness update-check  일/주 단위 업데이트 확인 실행
  ./harness manifest      .harness/shared-manifest.json 재생성 (하네스 레포 전용)
  ./harness skills-link   .claude/skills 및 .agents/skills 머지 트리 재생성
  ./harness profile       프로젝트 profile mode 조회/변경
  ./harness workflow-check actionlint 사용 가능 시 GitHub Actions workflow 점검
  ./harness notify-decision 사용자 결정이 필요함을 알림
  ./harness init-project  codi-{project} 모노레포 초기화
  ./harness wire-infisical <name>
                           Infisical 콘솔 작업 후 _PROJECT_ID_ 치환과 GitHub Secrets 등록
  ./harness team          선택형 cmux/tmux 팀 모드 실행
  ./harness codex         공통 preflight 실행 후 Codex 시작
  ./harness claude        공통 preflight 실행 후 Claude Code 시작
EOF
    ;;
  *)
    echo "알 수 없는 명령입니다: $cmd" >&2
    echo "./harness help 를 실행해 사용법을 확인하세요." >&2
    exit 2
    ;;
esac
